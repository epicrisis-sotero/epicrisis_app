{
  "name": "epicrisis-annotation-platform",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"API,UI\" -c \"yellow,cyan\" \"npm run dev:api\" \"npm run dev:ui\"",
    "dev:api": "tsx watch server/dev.ts",
    "dev:ui": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx db/migrate.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.4",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.30.10",
    "jose": "^5.2.3",
    "marked": "^12.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@vercel/node": "^3.0.20",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.21.4",
    "pg": "^8.11.5",
    "@types/pg": "^8.11.6",
    "express": "^4.19.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3",
    "vite": "^5.2.7",
    "vue-tsc": "^2.0.13"
  }
}
