{
  "name": "epicrisis-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "concurrently -k -p \"[{name}]\" -n \"API,UI\" -c \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --workspace=frontend",
    "lint": "npm run lint --workspace=frontend",
    "db:push": "npm run db:push --workspace=backend",
    "db:generate": "npm run db:generate --workspace=backend",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:studio": "npm run db:studio --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}