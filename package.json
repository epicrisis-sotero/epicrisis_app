{
  "name": "epicrisis-backend",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "bot": "tsx watch bot/index.ts",
    "bot:once": "tsx bot/index.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "tsx db/migrate.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.30.10",
    "grammy": "^1.43.0",
    "jose": "^5.2.3",
    "node-cron": "^4.2.1",
    "pg": "^8.11.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.6",
    "@vercel/node": "^3.0.20",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.21.4",
    "express": "^4.19.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3"
  }
}
