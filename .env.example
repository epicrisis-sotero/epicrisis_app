# PostgreSQL local (o cualquier instancia compatible)
DATABASE_URL="postgresql://user:password@localhost:5432/epicrisis"

# Auth — generate with: openssl rand -base64 64
JWT_SECRET=change_me_at_least_32_chars_long

# CORS origin (URL del frontend en Vercel)
CORS_ORIGIN=https://your-app.vercel.app

# URL pública del túnel ngrok — el bot la usa para verificar que el túnel esté arriba
NGROK_URL=https://your-domain.ngrok-free.dev

# HU-001 — umbral de criterios "?" (unknown) que deriva una epicrisis a revisión
# experta al enviar la anotación final. Entero >= 1. Valores inválidos o < 1 caen a 3.
EXPERT_REVIEW_UNKNOWN_THRESHOLD=3
